<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/drawer_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    tools:context=".MainActivity">

    <!-- 홈 본문과 왼쪽 Drawer 메뉴를 함께 담는 최상위 화면이다. -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/white"
        android:orientation="vertical">

        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="@color/white"
            android:elevation="0dp"
            app:popupTheme="@style/ToolbarPopupTheme"
            app:theme="@style/ToolbarIconColor"
            app:titleTextColor="@color/book_ink" />

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:clipToPadding="false"
            android:fillViewport="true"
            android:paddingBottom="18dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- 앱 로고, 이름, 프로필 아이콘이 있는 홈 상단이다. -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingStart="22dp"
                    android:paddingTop="8dp"
                    android:paddingEnd="22dp"
                    android:paddingBottom="18dp">

                    <ImageView
                        android:id="@+id/main_logo"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:contentDescription="@string/app_name"
                        android:scaleType="fitCenter"
                        android:src="@drawable/brand_app_icon" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:layout_weight="1"
                        android:text="@string/app_name"
                        android:textColor="@color/book_ink"
                        android:textSize="27sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="42dp"
                        android:layout_height="42dp"
                        android:gravity="center"
                        android:text="@string/home_profile_icon"
                        android:textColor="@color/book_ink"
                        android:textSize="26sp" />
                </LinearLayout>

                <!-- 앱을 처음 연 사용자가 바로 볼 수 있는 짧은 환영문구다. -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingStart="22dp"
                    android:paddingEnd="22dp"
                    android:paddingBottom="18dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/home_welcome_message"
                        android:textColor="@color/book_ink"
                        android:textSize="21sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="@string/home_welcome_subtitle"
                        android:textColor="@color/book_gray"
                        android:textSize="14sp" />
                </LinearLayout>

                <!-- 추천 탭과 랜덤 추천 탭을 보여 주는 제목 줄이다. -->
                <LinearLayout
                    android:id="@+id/curator_feed_card"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingStart="22dp"
                    android:paddingEnd="22dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="54dp"
                        android:gravity="center_vertical"
                        android:text="@string/home_tab_recommend"
                        android:textColor="@color/book_ink"
                        android:textSize="25sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/home_random_tab"
                        android:layout_width="wrap_content"
                        android:layout_height="54dp"
                        android:layout_marginStart="34dp"
                        android:clickable="true"
                        android:focusable="true"
                        android:gravity="center_vertical"
                        android:text="@string/home_tab_following"
                        android:textColor="@color/book_gray"
                        android:textSize="25sp" />
                </LinearLayout>

                <View
                    android:layout_width="74dp"
                    android:layout_height="4dp"
                    android:layout_marginStart="22dp"
                    android:background="@color/book_ink" />

                <HorizontalScrollView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="22dp"
                    android:overScrollMode="never"
                    android:paddingStart="22dp"
                    android:paddingEnd="22dp"
                    android:scrollbars="none">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="44dp"
                            android:layout_marginEnd="10dp"
                            android:background="@drawable/logo_badge"
                            android:gravity="center"
                            android:paddingStart="20dp"
                            android:paddingEnd="20dp"
                            android:text="@string/list_chip_all"
                            android:textColor="@color/white"
                            android:textSize="16sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="44dp"
                            android:layout_marginEnd="10dp"
                            android:background="@drawable/panel_soft_round"
                            android:gravity="center"
                            android:paddingStart="20dp"
                            android:paddingEnd="20dp"
                            android:text="@string/home_chip_post"
                            android:textColor="@color/book_ink"
                            android:textSize="16sp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="44dp"
                            android:layout_marginEnd="10dp"
                            android:background="@drawable/panel_soft_round"
                            android:gravity="center"
                            android:paddingStart="20dp"
                            android:paddingEnd="20dp"
                            android:text="@string/home_chip_review"
                            android:textColor="@color/book_ink"
                            android:textSize="16sp" />

                    </LinearLayout>
                </HorizontalScrollView>

                <!-- 마지막에 본 책 한 권을 크게 보여 주는 카드 영역이다. -->
                <LinearLayout
                    android:id="@+id/last_viewed_section"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="22dp"
                    android:layout_marginTop="24dp"
                    android:layout_marginEnd="22dp"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/home_last_viewed_title"
                        android:textColor="@color/book_ink"
                        android:textSize="22sp"
                        android:textStyle="bold" />

                    <LinearLayout
                        android:id="@+id/last_viewed_card"
                        android:layout_width="match_parent"
                        android:layout_height="142dp"
                        android:layout_marginTop="12dp"
                        android:background="@drawable/panel_feed_card"
                        android:clickable="true"
                        android:elevation="3dp"
                        android:focusable="true"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingStart="14dp"
                        android:paddingEnd="14dp">

                        <ImageView
                            android:id="@+id/last_viewed_cover"
                            android:layout_width="72dp"
                            android:layout_height="104dp"
                            android:background="@drawable/cover_shadow"
                            android:contentDescription="@string/home_last_viewed_title"
                            android:padding="1dp"
                            android:scaleType="centerCrop"
                            android:src="@drawable/book_cover_01" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="14dp"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/last_viewed_title"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:ellipsize="end"
                                android:maxLines="2"
                                android:text="@string/home_no_last_viewed"
                                android:textColor="@color/book_ink"
                                android:textSize="18sp"
                                android:textStyle="bold" />

                            <TextView
                                android:id="@+id/last_viewed_meta"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="7dp"
                                android:ellipsize="end"
                                android:maxLines="1"
                                android:text="@string/home_last_viewed_empty_meta"
                                android:textColor="@color/book_gray"
                                android:textSize="14sp" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="34dp"
                                android:layout_marginTop="13dp"
                                android:background="@drawable/logo_badge"
                                android:gravity="center"
                                android:paddingStart="16dp"
                                android:paddingEnd="16dp"
                                android:text="@string/home_last_viewed_button"
                                android:textColor="@color/white"
                                android:textSize="13sp"
                                android:textStyle="bold" />
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>

                <!-- 최근에 열어 본 책들을 가로 스크롤로 보여 주는 영역이다. -->
                <LinearLayout
                    android:id="@+id/recent_viewed_section"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="26dp"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:paddingStart="22dp"
                        android:paddingEnd="22dp"
                        android:text="@string/home_recent_viewed_title"
                        android:textColor="@color/book_ink"
                        android:textSize="22sp"
                        android:textStyle="bold" />

                    <HorizontalScrollView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:overScrollMode="never"
                        android:paddingStart="22dp"
                        android:paddingEnd="22dp"
                        android:scrollbars="none">

                        <LinearLayout
                            android:id="@+id/recent_books_container"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:paddingBottom="6dp" />
                    </HorizontalScrollView>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="22dp"
                    android:layout_marginTop="30dp"
                    android:layout_marginEnd="22dp"
                    android:background="@drawable/panel_feed_card"
                    android:elevation="4dp"
                    android:orientation="vertical">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="74dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingStart="18dp"
                        android:paddingEnd="14dp">

                        <TextView
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:background="@drawable/panel_soft_round"
                            android:gravity="center"
                            android:text="@string/home_avatar"
                            android:textColor="@color/book_gray"
                            android:textSize="22sp" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="12dp"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:ellipsize="end"
                                android:maxLines="1"
                                android:text="@string/home_feed_user"
                                android:textColor="@color/book_ink"
                                android:textSize="18sp"
                                android:textStyle="bold" />

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="3dp"
                                android:text="@string/home_feed_meta"
                                android:textColor="@color/book_gray"
                                android:textSize="14sp" />
                        </LinearLayout>

                        <com.google.android.material.button.MaterialButton
                            android:layout_width="88dp"
                            android:layout_height="46dp"
                            android:text="@string/home_follow_button"
                            android:textColor="@color/white"
                            android:textStyle="bold"
                            app:backgroundTint="@color/jnu_green"
                            app:cornerRadius="7dp" />
                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="@color/book_line" />

                    <!-- 누르면 상세 화면으로 들어가는 대표 추천 책 본문이다. -->
                    <LinearLayout
                        android:id="@+id/curator_book_area"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@color/screen_bg"
                        android:clickable="true"
                        android:focusable="true"
                        android:gravity="center_horizontal"
                        android:orientation="vertical"
                        android:paddingStart="18dp"
                        android:paddingTop="28dp"
                        android:paddingEnd="18dp"
                        android:paddingBottom="30dp">

                        <ImageView
                            android:layout_width="132dp"
                            android:layout_height="184dp"
                            android:background="@drawable/cover_shadow"
                            android:contentDescription="@string/book_detail_title"
                            android:elevation="5dp"
                            android:padding="2dp"
                            android:scaleType="centerCrop"
                            android:src="@drawable/book_cover_02" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="22dp"
                            android:gravity="center"
                            android:text="@string/home_feed_book_title"
                            android:textColor="@color/book_ink"
                            android:textSize="25sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="7dp"
                            android:gravity="center"
                            android:text="@string/home_feed_book_author"
                            android:textColor="@color/book_gray"
                            android:textSize="17sp" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="24dp"
                            android:gravity="center"
                            android:lineSpacingExtra="5dp"
                            android:text="@string/home_feed_quote"
                            android:textColor="@color/book_ink"
                            android:textSize="20sp" />
                    </LinearLayout>
                </LinearLayout>

                <!-- MainActivity에서 만든 작은 추천 카드들이 여기에 추가된다. -->
                <LinearLayout
                    android:id="@+id/curator_more_container"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="22dp"
                    android:layout_marginTop="16dp"
                    android:layout_marginEnd="22dp"
                    android:orientation="vertical" />

                <!-- 상품 목록과 장바구니로 바로 이동하는 주요 버튼 묶음이다. -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="22dp"
                    android:layout_marginTop="24dp"
                    android:layout_marginEnd="22dp"
                    android:orientation="horizontal">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/go_list_button"
                        android:layout_width="0dp"
                        android:layout_height="56dp"
                        android:layout_marginEnd="10dp"
                        android:layout_weight="1"
                        android:text="@string/go_book_list"
                        android:textColor="@color/white"
                        android:textStyle="bold"
                        app:backgroundTint="@color/jnu_green"
                        app:cornerRadius="28dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/cart_button"
                        android:layout_width="0dp"
                        android:layout_height="56dp"
                        android:layout_weight="1"
                        android:text="@string/home_cart_button"
                        android:textColor="@color/book_ink"
                        android:textStyle="bold"
                        app:backgroundTint="@color/campus_yellow"
                        app:cornerRadius="28dp" />
                </LinearLayout>

                <!-- 마지막 본 상품과 로그인 화면으로 이동하는 보조 버튼 묶음이다. -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="22dp"
                    android:layout_marginTop="12dp"
                    android:layout_marginEnd="22dp"
                    android:orientation="horizontal">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/last_book_button"
                        android:layout_width="0dp"
                        android:layout_height="54dp"
                        android:layout_marginEnd="10dp"
                        android:layout_weight="1"
                        android:text="@string/go_last_book"
                        android:textColor="@color/book_ink"
                        android:textStyle="bold"
                        app:backgroundTint="@color/white"
                        app:cornerRadius="27dp"
                        app:strokeColor="@color/book_line"
                        app:strokeWidth="1dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/login_shortcut_button"
                        android:layout_width="0dp"
                        android:layout_height="54dp"
                        android:layout_weight="1"
                        android:text="@string/home_login_button"
                        android:textColor="@color/book_ink"
                        android:textStyle="bold"
                        app:backgroundTint="@color/white"
                        app:cornerRadius="27dp"
                        app:strokeColor="@color/book_line"
                        app:strokeWidth="1dp" />
                </LinearLayout>
            </LinearLayout>
        </ScrollView>

        <include
            android:id="@+id/bottom_nav"
            layout="@layout/bottom_nav_home" />
    </LinearLayout>

    <com.google.android.material.navigation.NavigationView
        android:id="@+id/main_drawer_view"
        android:layout_width="290dp"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        app:headerLayout="@layout/nav_header"
        app:menu="@menu/menu_navigation" />
</androidx.drawerlayout.widget.DrawerLayout>
