<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    android:fitsSystemWindows="true"
    android:orientation="vertical"
    tools:context=".MyPageActivity">

    <!-- 로그인 상태, 최근 본 상품, 저장한 메모를 보여 주는 내서재 화면이다. -->
    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/white"
        android:elevation="0dp"
        app:popupTheme="@style/ToolbarPopupTheme"
        app:theme="@style/ToolbarIconColor"
        app:titleTextColor="@color/book_ink" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="22dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingStart="22dp"
                android:paddingTop="6dp"
                android:paddingEnd="22dp"
                android:text="@string/my_library_title"
                android:textColor="@color/book_ink"
                android:textSize="34sp"
                android:textStyle="bold" />

            <!-- 로그인 여부에 따라 이름과 안내 문구가 바뀌는 프로필 영역이다. -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="112dp"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingStart="22dp"
                android:paddingEnd="22dp">

                <FrameLayout
                    android:layout_width="146dp"
                    android:layout_height="112dp">

                    <TextView
                        android:layout_width="96dp"
                        android:layout_height="96dp"
                        android:background="@drawable/panel_soft_round"
                        android:gravity="center"
                        android:text="@string/home_avatar"
                        android:textColor="@color/book_gray"
                        android:textSize="38sp" />

                    <TextView
                        android:layout_width="98dp"
                        android:layout_height="wrap_content"
                        android:layout_gravity="bottom|start"
                        android:layout_marginStart="0dp"
                        android:layout_marginBottom="0dp"
                        android:background="@drawable/panel_yellow_round"
                        android:gravity="center"
                        android:text="@string/my_bubble_text"
                        android:textColor="@color/book_ink"
                        android:textSize="12sp"
                        android:textStyle="bold" />
                </FrameLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="18dp"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/profile_name_text"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/my_profile_name"
                        android:textColor="@color/book_ink"
                        android:textSize="24sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/login_status_text"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:lineSpacingExtra="3dp"
                        android:textColor="@color/book_gray"
                        android:textSize="15sp" />
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="72dp"
                android:orientation="horizontal"
                android:paddingStart="22dp"
                android:paddingEnd="22dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="@string/my_stat_highlight"
                    android:textColor="@color/book_ink"
                    android:textSize="17sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="@string/my_stat_post"
                    android:textColor="@color/book_ink"
                    android:textSize="17sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="@string/my_stat_review"
                    android:textColor="@color/book_ink"
                    android:textSize="17sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="@string/my_stat_write"
                    android:textColor="@color/book_ink"
                    android:textSize="17sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- 로그인/로그아웃과 장바구니 이동 버튼을 나란히 둔 영역이다. -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:orientation="horizontal"
                android:paddingStart="22dp"
                android:paddingEnd="22dp">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/login_button"
                    android:layout_width="0dp"
                    android:layout_height="52dp"
                    android:layout_marginEnd="10dp"
                    android:layout_weight="1"
                    android:text="@string/my_write_button"
                    android:textColor="@color/white"
                    android:textStyle="bold"
                    app:backgroundTint="@color/jnu_green"
                    app:cornerRadius="26dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/order_button"
                    android:layout_width="0dp"
                    android:layout_height="52dp"
                    android:layout_weight="1"
                    android:text="@string/my_shelf_button"
                    android:textColor="@color/book_ink"
                    android:textStyle="bold"
                    app:backgroundTint="@color/white"
                    app:cornerRadius="26dp"
                    app:strokeColor="@color/book_line"
                    app:strokeWidth="1dp" />
            </LinearLayout>

            <!-- 앱 소개와 강조 문구를 보여 주는 노란 안내 배너다. -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="82dp"
                android:layout_marginStart="22dp"
                android:layout_marginTop="18dp"
                android:layout_marginEnd="22dp"
                android:background="@drawable/panel_yellow_round"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingStart="18dp"
                android:paddingEnd="16dp">

                <ImageView
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:contentDescription="@string/app_name"
                    android:scaleType="fitCenter"
                    android:src="@drawable/brand_app_icon" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="14dp"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/my_yellow_banner_title"
                        android:textColor="@color/book_ink"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="@string/my_yellow_banner_message"
                        android:textColor="@color/book_gray"
                        android:textSize="14sp" />
                </LinearLayout>

                <TextView
                    android:layout_width="34dp"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:text="@string/arrow_right_text"
                    android:textColor="@color/book_ink"
                    android:textSize="28sp" />
            </LinearLayout>

            <!-- 마지막에 본 상품 한 권을 크게 보여 주는 영역이다. -->
            <LinearLayout
                android:id="@+id/my_last_viewed_section"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="22dp"
                android:layout_marginTop="24dp"
                android:layout_marginEnd="22dp"
                android:orientation="vertical">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/home_last_viewed_title"
                    android:textColor="@color/book_ink"
                    android:textSize="22sp"
                    android:textStyle="bold" />

                <LinearLayout
                    android:id="@+id/my_last_viewed_card"
                    android:layout_width="match_parent"
                    android:layout_height="128dp"
                    android:layout_marginTop="10dp"
                    android:background="@drawable/panel_feed_card"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp">

                    <ImageView
                        android:id="@+id/my_last_viewed_cover"
                        android:layout_width="64dp"
                        android:layout_height="92dp"
                        android:background="@drawable/cover_shadow"
                        android:contentDescription="@string/home_last_viewed_title"
                        android:padding="1dp"
                        android:scaleType="centerCrop"
                        android:src="@drawable/book_cover_01" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="13dp"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/my_last_viewed_title"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:ellipsize="end"
                            android:maxLines="2"
                            android:text="@string/home_no_last_viewed"
                            android:textColor="@color/book_ink"
                            android:textSize="18sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/my_last_viewed_meta"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="7dp"
                            android:ellipsize="end"
                            android:maxLines="1"
                            android:text="@string/home_last_viewed_empty_meta"
                            android:textColor="@color/book_gray"
                            android:textSize="14sp" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>

            <!-- 최근 본 상품을 가로 스크롤로 다시 확인하는 영역이다. -->
            <LinearLayout
                android:id="@+id/my_recent_viewed_section"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:orientation="vertical">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingStart="22dp"
                    android:paddingEnd="22dp"
                    android:text="@string/home_recent_viewed_title"
                    android:textColor="@color/book_ink"
                    android:textSize="22sp"
                    android:textStyle="bold" />

                <HorizontalScrollView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:overScrollMode="never"
                    android:paddingStart="22dp"
                    android:paddingEnd="22dp"
                    android:scrollbars="none">

                    <LinearLayout
                        android:id="@+id/my_recent_books_container"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:paddingBottom="6dp" />
                </HorizontalScrollView>
            </LinearLayout>

            <!-- 현재 장바구니에 담긴 상품 수와 요약을 보여 주는 영역이다. -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="22dp"
                android:layout_marginTop="20dp"
                android:layout_marginEnd="22dp"
                android:background="@drawable/panel_soft_round"
                android:orientation="vertical"
                android:padding="18dp">

                <TextView
                    android:id="@+id/cart_count_text"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/book_ink"
                    android:textSize="20sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/cart_summary_text"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:lineSpacingExtra="4dp"
                    android:textColor="@color/book_gray"
                    android:textSize="15sp" />
            </LinearLayout>
        </LinearLayout>
    </ScrollView>
</LinearLayout>
