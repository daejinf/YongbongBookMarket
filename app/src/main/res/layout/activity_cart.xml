<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/screen_bg"
    android:fitsSystemWindows="true"
    android:orientation="vertical"
    tools:context=".CartActivity">

    <!-- 선택 가능한 장바구니 목록과 주문 버튼을 함께 보여 주는 화면이다. -->
    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/white"
        android:elevation="0dp"
        app:popupTheme="@style/ToolbarPopupTheme"
        app:theme="@style/ToolbarIconColor"
        app:titleTextColor="@color/book_ink" />

    <!-- 전체 선택 체크박스와 삭제 버튼을 둔 상단 조작 영역이다. -->
    <LinearLayout
        android:id="@+id/select_all_row"
        android:layout_width="match_parent"
        android:layout_height="58dp"
        android:background="@color/white"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="18dp"
        android:paddingEnd="18dp">

        <CheckBox
            android:id="@+id/select_all_checkbox"
            android:layout_width="34dp"
            android:layout_height="34dp"
            android:buttonTint="@color/campus_yellow"
            android:checked="true" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_marginStart="8dp"
            android:layout_weight="1"
            android:gravity="center_vertical"
            android:text="@string/cart_select_all"
            android:textColor="@color/book_ink"
            android:textSize="16sp" />

    </LinearLayout>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="10dp"
        android:background="@color/screen_bg" />

    <!-- 배송 묶음 선택과 무료배송 안내를 보여 주는 영역이다. -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="104dp"
        android:background="@color/white"
        android:orientation="vertical"
        android:paddingStart="18dp"
        android:paddingTop="16dp"
        android:paddingEnd="18dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="32dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <CheckBox
                android:id="@+id/delivery_checkbox"
                android:layout_width="34dp"
                android:layout_height="34dp"
                android:buttonTint="@color/campus_yellow"
                android:checked="true" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:gravity="center_vertical"
                android:text="@string/cart_delivery_group"
                android:textColor="@color/book_ink"
                android:textSize="21sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:gravity="center"
                android:text="@string/cart_delivery_fee"
                android:textColor="@color/book_ink"
                android:textSize="15sp" />
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="7dp"
            android:layout_marginTop="18dp"
            android:background="@color/campus_yellow" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="28dp"
            android:gravity="center_vertical"
            android:text="@string/cart_free_shipping_line"
            android:textColor="@color/book_ink"
            android:textSize="14sp"
            android:textStyle="bold" />
    </LinearLayout>

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="@color/screen_bg">

        <!-- 장바구니가 비었을 때는 안내 문구, 상품이 있으면 RecyclerView가 보인다. -->
        <TextView
            android:id="@+id/empty_cart_text"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:text="@string/cart_empty"
            android:textColor="@color/book_gray"
            android:textSize="17sp" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/cart_recycler_view"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:padding="10dp"
            android:visibility="gone"
            tools:listitem="@layout/item_cart" />
    </FrameLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="118dp"
        android:background="@color/white"
        android:elevation="8dp"
        android:orientation="vertical"
        android:paddingStart="14dp"
        android:paddingTop="12dp"
        android:paddingEnd="14dp"
        android:paddingBottom="12dp">

        <!-- 선택된 상품의 합계 금액을 보여 주는 하단 고정 영역이다. -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="32dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center_vertical"
                android:text="@string/cart_summary_title"
                android:textColor="@color/book_ink"
                android:textSize="17sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/cart_total_text"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:gravity="center_vertical"
                android:textColor="@color/book_ink"
                android:textSize="22sp"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="58dp"
            android:layout_marginTop="8dp"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/keep_shopping_button"
                android:layout_width="0dp"
                android:layout_height="54dp"
                android:layout_marginEnd="8dp"
                android:layout_weight="1"
                android:text="@string/cart_keep_shopping"
                android:textColor="@color/book_ink"
                android:textStyle="bold"
                app:backgroundTint="@color/white"
                app:cornerRadius="4dp"
                app:strokeColor="@color/book_line"
                app:strokeWidth="1dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/order_button"
                android:layout_width="0dp"
                android:layout_height="54dp"
                android:layout_weight="1"
                android:text="@string/cart_order_button"
                android:textColor="@color/book_ink"
                android:textStyle="bold"
                app:backgroundTint="@color/campus_yellow"
                app:cornerRadius="4dp" />
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
