<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/screen_bg"
    android:fitsSystemWindows="true"
    android:orientation="vertical"
    tools:context=".LoginActivity">

    <!--
        로그인 화면의 Toolbar이다.
        이 화면은 장바구니에서 주문 단계로 넘어가기 전에 열릴 수 있으므로 뒤로가기 버튼을 둔다.
    -->
    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/white"
        android:elevation="1dp"
        app:popupTheme="@style/ToolbarPopupTheme"
        app:theme="@style/ToolbarIconColor"
        app:titleTextColor="@color/book_ink" />

    <!--
        아이디, 이름, 비밀번호를 입력받는 간단 로그인 폼이다.
        입력값은 Kotlin 코드에서 SharedPreferences에 저장한다.
        기본 EditText만 사용해 입력 흐름을 단순하게 유지했다.
    -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="22dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/panel_soft_green"
            android:padding="16dp"
            android:text="@string/login_guide"
            android:textColor="@color/book_ink"
            android:textSize="18sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:background="@drawable/panel_card_modern"
            android:orientation="vertical"
            android:padding="18dp">

            <EditText
                android:id="@+id/student_id_edit"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:hint="@string/login_student_id_hint"
                android:inputType="text"
                android:singleLine="true"
                android:textColor="@color/book_ink" />

            <EditText
                android:id="@+id/name_edit"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:layout_marginTop="8dp"
                android:hint="@string/login_name_hint"
                android:inputType="textPersonName"
                android:singleLine="true"
                android:textColor="@color/book_ink" />

            <EditText
                android:id="@+id/password_edit"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:layout_marginTop="8dp"
                android:hint="@string/login_password_hint"
                android:inputType="textPassword"
                android:singleLine="true"
                android:textColor="@color/book_ink" />

            <Button
                android:id="@+id/login_button"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:layout_marginTop="18dp"
                android:backgroundTint="@color/campus_yellow"
                android:text="@string/login_button"
                android:textColor="@color/book_ink"
                android:textStyle="bold" />
        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:lineSpacingExtra="4dp"
            android:text="@string/login_scope_note"
            android:textColor="@color/book_gray"
            android:textSize="13sp" />
    </LinearLayout>
</LinearLayout>
